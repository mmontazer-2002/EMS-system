<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE struts PUBLIC
        "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
        "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>

    <package name="default"
             namespace="/"
             extends="struts-default">

        <action name="login" class="ir.gam.action.LoginAction">
            <result name="success">/pages/dashboard.jsp</result>
            <result name="error">/pages/login.jsp</result>
        </action>

        <action name="employeeForm">
            <result>/pages/employee-form.jsp</result>
        </action>

        <action name="save" class="ir.gam.action.EmployeeAction" method="save">
            <result name="success">/pages/success.jsp</result>
        </action>

    </package>


</struts>